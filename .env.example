# Telegram bot token from @BotFather
BOT_TOKEN=123456789:replace-with-real-token
# Your own numeric Telegram user ID (message @userinfobot to find it)
TREASURER_TELEGRAM_ID=12345678
# SQLite file path (default is fine)
DB_PATH=clubbot.db
# Gemini API key from Google AI Studio (needed for receipt verification).
# Use a billing-enabled (paid) key so submitted receipts are not used to train
# Google's models; the code is identical for the free tier.
GEMINI_API_KEY=
# Kept configurable so model upgrades do not require code changes
GEMINI_MODEL=gemini-2.5-flash
# --- Google Sheet mirror (optional; leave blank to disable) ---
# Path to the Google service-account JSON key file (see DEPLOY.md).
GOOGLE_SERVICE_ACCOUNT_JSON=
# The target spreadsheet's ID (the long token in its URL), shared with the
# service-account email as Editor.
SHEET_ID=
